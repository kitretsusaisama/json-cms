{
  "name": "@upflame/adapter-nextjs",
  "version": "1.0.0",
  "description": "DEPRECATED compatibility package. Use @upflame/adapters/nextjs.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-package.mjs .",
    "test": "vitest run --config vitest.config.ts src/__tests__/adapter-contract.test.ts",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4",
    "@upflame/adapter-contract": "^0.1.0"
  }
}
