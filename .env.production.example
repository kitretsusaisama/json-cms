# Production Environment Variables
# Copy this file to .env.production and update the values

# === CORE APPLICATION ===
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://albata.com
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXTAUTH_URL=https://albata.com
NEXTAUTH_SECRET=your-super-secret-nextauth-secret-here

# === DATABASE ===
DATABASE_URL=postgresql://user:password@localhost:5432/albata_prod
DATABASE_SSL=true
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30000

# === REDIS CACHE ===
REDIS_URL=redis://user:password@redis-host:6379
REDIS_PREFIX=albata:prod:
REDIS_TTL=3600

# === SECURITY ===
ENCRYPTION_KEY=your-32-character-encryption-key-here
JWT_SECRET=your-jwt-secret-key-here
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# === EMAIL & NOTIFICATIONS ===
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@albata.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx

# === PAYMENTS ===
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx

# === CLOUD STORAGE ===
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=albata-production-assets
AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net

# === CDN & PERFORMANCE ===
CLOUDFLARE_ZONE_ID=xxx
CLOUDFLARE_API_TOKEN=xxx
NEXT_PUBLIC_CDN_URL=https://cdn.albata.com

# === MONITORING & LOGGING ===
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=albata
SENTRY_PROJECT=web-app
DATADOG_API_KEY=xxx
DATADOG_APP_KEY=xxx
NEW_RELIC_LICENSE_KEY=xxx

# === ANALYTICS ===
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXXX
MIXPANEL_TOKEN=xxx
POSTHOG_KEY=phc_xxx
POSTHOG_HOST=https://app.posthog.com

# === OAUTH PROVIDERS ===
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx
MICROSOFT_CLIENT_ID=xxx
MICROSOFT_CLIENT_SECRET=xxx

# === SEARCH ===
ALGOLIA_APP_ID=xxx
ALGOLIA_API_KEY=xxx
ALGOLIA_SEARCH_KEY=xxx

# === SEO & VERIFICATION ===
GOOGLE_SITE_VERIFICATION=xxx
BING_SITE_VERIFICATION=xxx
YANDEX_SITE_VERIFICATION=xxx
PINTEREST_SITE_VERIFICATION=xxx

# === WEBHOOKS ===
WEBHOOK_PAYMENT_SUCCESS_URL=https://external-api.com/webhooks/payment
WEBHOOK_USER_SIGNUP_URL=https://external-api.com/webhooks/user
WEBHOOK_AUTH_TOKEN=bearer-token-for-webhook-auth

# === CRM & INTEGRATIONS ===
HUBSPOT_API_KEY=xxx
HUBSPOT_PORTAL_ID=xxx
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1234567890

# === PUSH NOTIFICATIONS ===
FCM_SERVER_KEY=xxx
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx

# === SAML (Enterprise) ===
SAML_ENTITY_ID=https://albata.com/saml/metadata
SAML_SSO_URL=https://idp.company.com/saml/sso
SAML_CERTIFICATE=-----BEGIN CERTIFICATE-----xxx-----END CERTIFICATE-----

# === BACKUP & MAINTENANCE ===
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key-here
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="Scheduled maintenance in progress"

# === FEATURE FLAGS ===
ENABLE_AI_FEATURES=false
ENABLE_BETA_FEATURES=false
ENABLE_ADMIN_PANEL=true
ENABLE_API_V2=true

# === SECURITY HEADERS ===
CSP_REPORT_URI=https://albata.report-uri.com/r/d/csp/enforce
HSTS_MAX_AGE=31536000
