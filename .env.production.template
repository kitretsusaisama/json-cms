# Production Environment Configuration
# Use this template for production deployments

# Application
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PORT=3000

# CMS Configuration
CMS_PROVIDER=database
CMS_CACHE_TTL=3600

# Database Configuration
DATABASE_URL=postgresql://cms_user:ultra_secure_password@prod-db:5432/cms_production
DATABASE_POOL_SIZE=20
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Redis Configuration
REDIS_URL=redis://prod-redis:6379
REDIS_PREFIX=cms:prod:
REDIS_CLUSTER=true
REDIS_PASSWORD=ultra_secure_redis_password

# Authentication
NEXTAUTH_SECRET=production-secret-key-generate-ultra-secure-random-string
NEXTAUTH_URL=https://yourdomain.com

# Auth Providers
# AUTH0_SECRET=production-auth0-secret
# AUTH0_BASE_URL=https://yourdomain.com
# AUTH0_ISSUER_BASE_URL=https://your-domain.auth0.com
# AUTH0_CLIENT_ID=production-auth0-client-id
# AUTH0_CLIENT_SECRET=production-auth0-client-secret

# Multi-tenant Configuration
MULTI_TENANT_ENABLED=true
TENANT_RESOLUTION_STRATEGY=domain
DEFAULT_TENANT_ID=production-default

# Security
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
CSP_ENABLED=true
CSP_REPORT_URI=https://yourdomain.com/api/csp-report
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=5000
RATE_LIMIT_WINDOW=900000
SECURITY_HEADERS=true

# SSL/TLS
FORCE_HTTPS=true
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Monitoring and Logging
LOG_LEVEL=warn
STRUCTURED_LOGGING=true
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
APM_ENABLED=true
AUDIT_LOGGING=true

# Performance
CACHE_ENABLED=true
CACHE_STRATEGY=redis
PERFORMANCE_MONITORING=true
CDN_ENABLED=true
COMPRESSION_ENABLED=true

# File Upload
UPLOAD_MAX_SIZE=104857600
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4
UPLOAD_STORAGE=s3
AWS_S3_BUCKET=cms-production-uploads
AWS_REGION=us-east-1
AWS_CLOUDFRONT_DOMAIN=cdn.yourdomain.com

# Email
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=ultra-secure-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# External Services
SENTRY_DSN=https://your-production-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
ANALYTICS_ID=your-production-analytics-id

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 1 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION=true

# Scaling Configuration
CLUSTER_MODE=true
MAX_WORKERS=4
MEMORY_LIMIT=2048

# Feature Flags
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_A_B_TESTING=true
FEATURE_REAL_TIME_COLLABORATION=true