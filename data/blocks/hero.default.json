{
  "id": "hero.default",
  "tree": [
    {
      "id": "hero-main",
      "key": "Hero",
      "props": {
        "heading": { "$i18n": "home.hero.heading" },
        "subheading": "Build composable, constraint-aware UIs with JSON",
        "image": {
          "src": "/images/hero-background.jpg",
          "alt": "Modern web development workflow"
        },
        "cta": {
          "text": { "$i18n": "common.getStarted" },
          "href": "/get-started"
        }
      },
      "variants": [
        {
          "name": "image-left",
          "props": {
            "layout": "image-left",
            "imagePosition": "left"
          },
          "weight": 3,
          "conditions": [
            {
              "when": {
                "op": "==",
                "args": [{ "$ctx": "device" }, "desktop"]
              }
            }
          ]
        },
        {
          "name": "image-top",
          "props": {
            "layout": "image-top",
            "imagePosition": "top"
          },
          "weight": 2,
          "conditions": [
            {
              "when": {
                "op": "in",
                "args": [{ "$ctx": "device" }, ["mobile", "tablet"]]
              }
            }
          ]
        },
        {
          "name": "minimal",
          "props": {
            "layout": "minimal",
            "showImage": false
          },
          "weight": 1,
          "conditions": [
            {
              "when": {
                "op": "==",
                "args": [{ "$ctx": "ab.heroVariant" }, "minimal"]
              }
            }
          ]
        }
      ],
      "weight": 4,
      "analytics": {
        "id": "hero-main",
        "tags": ["conversion", "above-fold"]
      }
    }
  ],
  "constraints": [
    {
      "id": "hero-has-heading",
      "rule": {
        "op": "has",
        "args": [{ "$ctx": "components.0.props" }, "heading"]
      }
    },
    {
      "id": "hero-has-cta",
      "rule": {
        "op": "has",
        "args": [{ "$ctx": "components.0.props" }, "cta"]
      }
    }
  ]
}
