{
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem", 
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "3xl": "4rem"
  },
  "color": {
    "primary": {
      "50": "#eff6ff",
      "100": "#dbeafe", 
      "500": "#3b82f6",
      "600": "#2563eb",
      "900": "#1e3a8a"
    },
    "gray": {
      "50": "#f9fafb",
      "100": "#f3f4f6",
      "500": "#6b7280",
      "800": "#1f2937",
      "900": "#111827"
    },
    "text": {
      "primary": "var(--color-gray-900)",
      "secondary": "var(--color-gray-500)",
      "muted": "var(--color-gray-400)"
    },
    "bg": {
      "primary": "var(--color-white)",
      "secondary": "var(--color-gray-50)",
      "accent": "var(--color-primary-50)"
    }
  },
  "typography": {
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500", 
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.75"
    }
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1)"
  }
}
