  "examples": {
    "pages": {
      "homepage": {
        "path": "pages/homepage.json",
        "description": "Complete homepage example with hero, features, testimonials, and CTA",
        "features": ["hero-section", "feature-grid", "testimonials", "newsletter-signup"],
        "complexity": "intermediate",
        "tags": ["marketing", "conversion", "homepage"]
      },
      "product-detail": {
        "path": "pages/product-detail.json",
        "description": "E-commerce product detail page with gallery, specs, and reviews",
        "features": ["product-gallery", "specifications", "reviews", "related-products"],
        "complexity": "advanced",
        "tags": ["ecommerce", "product", "conversion"]
      },
      "blog-post": {
        "path": "pages/blog-post.json",
        "description": "Blog post page with reading progress, social sharing, and comments",
        "features": ["reading-progress", "social-sharing", "comments", "related-articles"],
        "complexity": "intermediate",
        "tags": ["blog", "content", "engagement"]
      }
    },
    
    "blocks": {
      "hero-homepage": {
        "path": "blocks/hero-homepage.json",
        "description": "Responsive hero block with multiple variants and constraints",
        "features": ["responsive-variants", "constraint-validation", "analytics-tracking"],
        "complexity": "advanced",
        "tags": ["hero", "responsive", "conversion"]
      },
      "features-overview": {
        "path": "blocks/features-overview.json",
        "description": "Feature grid with conditional rendering and device-specific layouts",
        "features": ["conditional-rendering", "device-targeting", "grid-layout"],
        "complexity": "intermediate",
        "tags": ["features", "grid", "responsive"]
      },
      "testimonials-featured": {
        "path": "blocks/testimonials-featured.json",
        "description": "Testimonial carousel with rating system and social proof",
        "features": ["carousel-layout", "rating-system", "social-proof"],
        "complexity": "intermediate",
        "tags": ["testimonials", "social-proof", "carousel"]
      }
    },
    
    "plugins": {
      "ecommerce-plugin": {
        "path": "plugins/ecommerce-plugin/",
        "description": "Complete e-commerce plugin with products, cart, and payment processing",
        "features": ["product-management", "shopping-cart", "payment-processing", "order-management"],
        "complexity": "advanced",
        "tags": ["ecommerce", "payments", "products", "orders"],
        "dependencies": ["stripe", "react", "next"],
        "apiEndpoints": [
          "/api/ecommerce/products",
          "/api/ecommerce/cart",
          "/api/ecommerce/orders"
        ],
        "components": [
          "ProductCard",
          "ProductGrid",
          "ShoppingCart",
          "PriceDisplay",
          "ProductFilters"
        ]
      }
    },
    
    "integrations": {
      "nextauth": {
        "path": "integrations/nextauth/setup.ts",
        "description": "Complete NextAuth.js setup with multiple providers and RBAC",
        "features": ["multi-provider-auth", "rbac", "session-management", "tenant-resolution"],
        "complexity": "advanced",
        "tags": ["authentication", "nextauth", "rbac", "multi-tenant"],
        "providers": ["google", "github", "email"],
        "dependencies": ["next-auth", "@next-auth/prisma-adapter"]
      },
      "stripe-payments": {
        "path": "integrations/stripe/payment-integration.ts",
        "description": "Stripe payment processing with subscriptions and webhooks",
        "features": ["payment-intents", "subscriptions", "webhooks", "customer-management"],
        "complexity": "advanced",
        "tags": ["payments", "stripe", "subscriptions", "webhooks"],
        "dependencies": ["stripe", "@stripe/stripe-js"]
      }
    },
    
    "templates": {
      "ecommerce": {
        "path": "templates/ecommerce/",
        "description": "Complete e-commerce template with product catalog and checkout",
        "features": [
          "product-catalog",
          "shopping-cart",
          "checkout-flow",
          "order-management",
          "payment-processing",
          "inventory-tracking",
          "customer-accounts",
          "seo-optimization"
        ],
        "complexity": "advanced",
        "tags": ["ecommerce", "template", "complete-solution"],
        "pages": [
          "homepage",
          "product-listing",
          "product-detail",
          "shopping-cart",
          "checkout",
          "account-pages"
        ],
        "integrations": ["stripe", "email", "analytics"],
        "estimatedSetupTime": "2-4 hours"
      },
      "blog": {
        "path": "templates/blog/",
        "description": "Modern blog template with content management and SEO",
        "features": [
          "article-system",
          "author-profiles",
          "category-organization",
          "search-functionality",
          "seo-optimization",
          "newsletter-integration",
          "comment-system",
          "social-sharing"
        ],
        "complexity": "intermediate",
        "tags": ["blog", "template", "content-management"],
        "pages": [
          "homepage",
          "blog-index",
          "article-detail",
          "category-pages",
          "author-pages",
          "search-results"
        ],
        "integrations": ["email", "analytics", "comments"],
        "estimatedSetupTime": "1-2 hours"
      }
    }
  },
  
