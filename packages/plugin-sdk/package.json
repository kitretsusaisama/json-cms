{
  "name": "@upflame/plugin-sdk",
  "version": "1.0.0",
  "description": "Plugin authoring SDK for the Upflame CMS ecosystem.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-package.mjs .",
    "test": "vitest run --config vitest.config.ts src/__tests__/define-plugin.test.ts src/__tests__/manifest.test.ts",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@upflame/schema-engine": "^1.0.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  }
}
