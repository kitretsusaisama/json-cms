    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@upflame/cms-core": "^0.1.0",
    "@upflame/runtime": "^0.1.0",
    "@upflame/plugin-sdk": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
