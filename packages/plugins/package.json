{
  "name": "@upflame/plugins",
  "version": "0.1.0",
  "description": "Plugin lifecycle and manifest boundary contracts.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
