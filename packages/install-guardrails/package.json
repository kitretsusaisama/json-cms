{
  "name": "@upflame/install-guardrails",
  "version": "0.1.0",
  "description": "Install-time compatibility checks for framework, adapters, and plugins.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./cli": {
      "types": "./dist/types/cli.d.ts",
      "import": "./dist/esm/cli.js",
      "require": "./dist/cjs/cli.js"
    }
  },
  "bin": {
    "jsoncms-install-guardrails": "./dist/esm/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-package.mjs .",
    "test": "vitest run --config vitest.config.ts src/__tests__/index.test.ts",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "semver": "^7.6.3"
  }
}
